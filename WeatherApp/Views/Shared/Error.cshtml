@{
    ViewBag.Title = "Ошибка";
}

<div class="container">
    <div class="error-box">
        <h3>⚠️ Что-то пошло не так</h3>

        @if (ViewBag.Error != null)
        {
            <p class="text-muted">@ViewBag.Error</p>
        }
        else
        {
            <p class="text-muted">Произошла непредвиденная ошибка</p>
        }

        <div class="mt-3">
            <a href="/" class="btn btn-primary">🏠 Вернуться на главную</a>
        </div>
    </div>
</div>